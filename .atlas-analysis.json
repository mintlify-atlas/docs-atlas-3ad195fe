  "keyFeatures": [
    "Centralised OAuth2 single sign-on for GOV.UK services",
    "Username/password authentication via Devise",
    "Two-step verification (2SV/TOTP) with mandatory enforcement",
    "Role-based access control (Superadmin, Admin, Organisation Admin, User)",
    "Application permission management with delegated permissions",
    "API user tokens for service-to-service authentication",
    "Batch user invitations",
    "Organisation hierarchy management",
    "Automatic account suspension for inactive users",
    "Event audit logging"
  ],
  "publicApiSurface": [
    "GET /api/users?uuids[]=<uuid> — Retrieve user details by UUID",
    "GET /user — OAuth user info endpoint (returns user permissions)",
    "POST /oauth/authorize — OAuth 2.0 authorization endpoint",
    "POST /oauth/token — OAuth 2.0 token endpoint",
    "POST /oauth/access_token — Legacy OAuth v1 compatibility endpoint",
    "GET /healthcheck/live — Liveness healthcheck",
    "GET /healthcheck/ready — Readiness healthcheck"
  ]
